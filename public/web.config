<?xml version="1.0" encoding="UTF-8"?>
<configuration>
  <system.webServer>
    <staticContent>
      <!-- Ensure the browser can download .cer certificate profiles for iOS trust -->
      <remove fileExtension=".cer" />
      <mimeMap fileExtension=".cer" mimeType="application/x-x509-ca-cert" />
      
      <!-- Support JSON files (for manifest.json) if not already configured in IIS -->
      <remove fileExtension=".json" />
      <mimeMap fileExtension=".json" mimeType="application/json" />
      
      <!-- Support SVG files (for icons and favicon) -->
      <remove fileExtension=".svg" />
      <mimeMap fileExtension=".svg" mimeType="image/svg+xml" />
    </staticContent>
  </system.webServer>
</configuration>
